app.use("*", (req, res) => {
  res.status(404).json({
    message: `${req.originalUrl} existiert nicht`,
    success: false
  })
});

app.use((error, req, res, next) => {
  console.log(`unerwarteter Fehler: ${error}`);
  res.status(500).json({
    message: `unerwarteter Fehler`,
    success: false,
    error: error.message
  })
})

async function startServer() {
  try {
    await initDB();

    await seedUsers();

    app.listen(PORT, HOST, () => {
      console.log(`Server läuft unter http://${HOST}:${PORT}`);
    })
  } catch (error) {
    console.log(`Fehler beim Starten des Servers: ${error}`);
    process.exit(1);
  }
}

startServer();
