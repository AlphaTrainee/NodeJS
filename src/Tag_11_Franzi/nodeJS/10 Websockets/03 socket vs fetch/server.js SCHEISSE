import express from "express";
import cors from "cors";
import path from "path";
import { createServer } from "node:http";
import { OP } from "sequelize";
import { sequelize, initDB, User, seedUsers } from "./models/index.js";

import 'dotenv/config';
const HOST = process.env.SERVER_HOST || 'localhost';
const PORT = process.env.SERVER_PORT || 3000;

// 1. Initialisierung
const app = express();
app.use(express.json());
app.use(cors());
app.use(express.urlencoded({ extended: true }));
app.use(express.static("public"));

// Routes (API Endpunkte)
app.get("/", async (req, res) => {
  try {
    const userCount = await User.count();
    res.json({
      message: "Express REST API connect to DB",
      totalUsers: userCount,
      endpoints: [
        " GET '/'        - Root-Endpunkt",
      ]
    });
  } catch (error) {
    console.log(`Fehler beim Abrufen der Seite: ${error}`);
    res.status(500).json({
      message: "Fehler beim Ermitteln der Useranzahl auf Root-Site",
      success: false,
      error: error.message
    })
  }
});

app.get("/api/users", async (req, res) => {
  try {
    console.log(`/api/users - Alle User abrufen`);

    const { name, minAge, maxAge } = req.query;

    // where filter
    const whereConditions = {};

    if (name) {
      whereConditions.name = {
        [OP.like]: `%${name}%`
      };
    }

    if (minAge || maxAge) {
      whereConditions.age = {};
      if (minAge) whereConditions.age[OP.gte] = minAge;
      if (maxAge) whereConditions.age[OP.lte] = maxAge;
    }

    const users = await User.findAll({
      where: whereConditions,
      order: ["createdAt DESC"]
    });


    res.json({
      message: "Alle User abgerufen",
      success: true,
      users: users,
      count: users.length
    });

  } catch (error) {
    console.log(`Fehler beim Abrufen der User: ${error}`);
    res.status(500).json({
      message: "Fehler beim Abrufen der User",
      success: false,
      error: error.message
    })
  }
});

app.get("/api/users/:id", async (req, res) => {
  try {
    const { id } = req.params;
    console.log(`/api/users/${id} - User abrufen`);

    const userId = parseInt(id);

    if (!userId) {
      return res.status(400).json({
        message: "Ungültige UserId",
        success: false
      });
    }

    const user = await User.findByPK(userId);

    if (!user) {
      return res.status(404).json({
        message: `kein User mit der ID ${id} gefunden`,
        success: false
      });
    }

    return res.status(404).json({
      message: `User erfolgreich abgerufen`,
      success: true,
      user: user
    });

  } catch (error) {
    console.log(`Fehler beim Abrufen des Users: ${req.params.id}: ${error}`);
    res.status(500).json({
      message: `Fehler beim Abrufen des Users: ${req.params.id}`,
      success: false,
      error: error.message
    })
  }
});

app.post("/api/users/", async (req, res) => {
  try {
    console.log(`POST /api/users - neuen user erstellen`);
    console.log(`Request Body: ${req.body}`);

    const { name, email, age } = req.body;

    if (!name || !email) {
      res.status(400).json({
        message: `Name und eMail sind erforderlich`,
        success: false,
        received: { name, email, age }
      })
    }

    const newUser = await user.create({
      name: name.trim(),
      email: email.trim(),
      age: age || null
    });

    res.status(200).json({
      message: "User erfolgreich erstellt",
      success: true,
      data: newUser
    })

  } catch (error) {
    console.log(`Fehler beim Erstellen des users ${error}`);

    if (error.name === "SequelizeUniqueContraintError") {
      return res.status(409).json({
        message: `Email adrese existiert`,
        success: false,
        error: error.message.map(err => err.message)
      })
    }

    if (error.name === "SequelizeValidationError") {
      return res.status(400).json({
        message: `Validierungsfehler`,
        success: false,
        error: error
      })
    }

    res.status(500).json({
      message: `Fehler beim Erstellen des users`,
      success: false,
      error: error.message
    })
  }
});
