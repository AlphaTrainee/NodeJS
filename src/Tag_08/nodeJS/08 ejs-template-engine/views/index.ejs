<%- include("./parts/head", {title: "Unsere Produkte", stylePath: "./style.css"}) %>

<body>
    <h1>Unsere Produkte</h1>
    <nav>
        <ul>
            <!-- start loop -->
            <% products.forEach((prod, idx) => {  %>
                <li>
                    <a href="/product/<%= idx %>"><%= prod.name %></a>
                    <!-- Kommentar: <%= prod.price %> -->
                     <%# ejs-Kommentar, der NICHT gerendert wird %>
                </li>
            <% }) %>
            <!-- end loop -->
        </ul>
    </nav>
</body>

</html>