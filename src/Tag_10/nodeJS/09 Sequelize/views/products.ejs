<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= name %></title>
    <link rel="stylesheet" href="./../style.css">
</head>
<body>
    <h2><%= name %></h2>
    <p>Beschreibung: <%= desc %></p>
    <p>Preis: <%= price %> EUR</p>

    <% if (qty < 20) { %>
        <p style="color:red;"">Warenbestand gering: <%= qty %> Stück</p>
    <% } %>

    <a href="/">Zurück zur Übersicht</a>
</body>
</html>