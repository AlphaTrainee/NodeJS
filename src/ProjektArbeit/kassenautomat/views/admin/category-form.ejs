<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <title><%= category ? 'Kategorie bearbeiten' : 'Neue Kategorie' %></title>
    <link rel="stylesheet" href="/admin_style.css">
</head>
<body>
    <h1><%= category ? 'Kategorie bearbeiten (ID: ' + category.id + ')' : 'Neue Kategorie anlegen' %></h1>

    <%- include('../partials/error-box') %>

    <div class="card">
        <form action="/admin/categories/<%= category ? 'edit/' + category.id : 'add' %>" method="POST">
            <label>Name:</label><br>
            <input type="text" name="name" value="<%= category ? category.name : '' %>" required><br><br>
            
            <label>Beschreibung:</label><br>
            <input type="text" name="description" value="<%= category ? category.description : '' %>"><br><br>

            <label>
                <input type="checkbox" name="visible" <%= (category === null || category.visible) ? 'checked' : '' %>>
                Im Frontend anzeigen
            </label><br><br>

            <div class="btn-submit">
                <button type="submit" class="btn-add">Speichern</button>
                <a href="/admin/categories" class="btn-cancel">Abbrechen</a>
            </div>
        </form>
    </div>
</body>
</html>