<!DOCTYPE html>
<html lang="de">

<head>
    <meta charset="UTF-8">
    <link rel="stylesheet" href="/admin_style.css">
    <title>Kategorien verwalten</title>
</head>

<body>
    <h1>Kategorien</h1>

    <div style="margin-bottom: 20px;">
        <a href="/admin" class="btn-edit">zur Übersicht</a>
        <a href="/admin/categories/add" class="btn-add">+ Neue Kategorie anlegen</a>
    </div>

    <%- include('../partials/error-box') %>

    <div class="card">
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th class="center-td">Sichtbar</th>
                    <th>Name</th>
                    <th>Beschreibung</th>
                    <th>Aktion</th>
                </tr>
            </thead>
            <tbody>
                <% kategorien.forEach(kategorie => { %>
                    <tr>
                        <td><%= kategorie.id %></td>
                        <td class="center-td">
                            <% if (kategorie.visible) { %>
                                <span class="visible icon">✔</span>
                            <% } else { %>
                                <span class="hidden icon">✘</span>
                            <% } %>
                        </td>
                        <td><%= kategorie.name %></td>
                        <td><%= kategorie.description %></td>
                        <td>
                            <a href="/admin/categories/edit/<%= kategorie.id %>" class="btn-edit">Bearbeiten</a>
                            <form action="/admin/categories/delete/<%= kategorie.id %>" method="POST"
                                style="display:inline;" onsubmit="return confirm('Wirklich löschen?')">
                                <button type="submit" class="btn-del">Löschen</button>
                            </form>
                        </td>
                    </tr>
                    <% }) %>
            </tbody>
        </table>
    </div>
</body>

</html>