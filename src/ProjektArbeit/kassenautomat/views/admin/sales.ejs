<!DOCTYPE html>
<html lang="de">

<head>
    <meta charset="UTF-8">
    <link rel="stylesheet" href="/admin_style.css">
    <title>Verkaufsstatistik</title>
</head>

<body>
    <h1>Verkaufs-Statistik</h1>

    <div style="margin-bottom: 20px;">
        <a href="/admin" class="btn-edit">zur Übersicht</a>
    </div>

    <%- include('../partials/error-box') %>

    <% if (grandTotal && sales ) { %>
    <!-- Statistik-Karten für den schnellen Überblick -->
    <div style="display: flex; gap: 20px; margin-bottom: 20px;">
        <div class="card" style="flex: 1; padding: 15px;">
            <h3 style="margin-top: 0;">Gesamtumsatz</h3>
            <p style="font-size: 1.5rem; font-weight: bold; color: #28a745; margin: 0;">
                <%= Number(grandTotal).toFixed(2) %> €
            </p>
        </div>
        <div class="card" style="flex: 1; padding: 15px;">
            <h3 style="margin-top: 0;">Verkäufe gesamt</h3>
            <p style="font-size: 1.5rem; font-weight: bold; margin: 0;">
                <%= sales.length %>
            </p>
        </div>
    </div>

    <div class="card">
        <table>
            <thead>
                <tr>
                    <th>Datum/Zeit</th>
                    <th>Zahlart</th>
                    <th>Summe</th>
                    <th>Tickets</th>
                </tr>
            </thead>
            <tbody>
                <% sales.forEach(sale => { %>
                    <tr>
                        <td><%= new Date(sale.createdAt).toLocaleString('de-DE') %></td>
                        <td><%= sale.paymentMethod %></td>
                        <td><strong><%= Number(sale.totalAmount).toFixed(2) %> €</strong></td>
                        <td>
                            <ul style="margin: 0; padding-left: 15px; font-size: 0.9rem;">
                                <% sale.SoldTickets.forEach(t => { %>
                                    <li><%= t.ticketName %></li>
                                <% }) %>
                            </ul>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
    <% } %>
</body>

</html>