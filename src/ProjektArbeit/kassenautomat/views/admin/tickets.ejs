<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <title>Stammdaten Verwaltung</title>
    <link rel="stylesheet" href="/admin_style.css">
</head>
<body>
    <h1>Ticket-Stammdaten</h1>

    <div style="margin-bottom: 20px;">
        <a href="/admin" class="btn-edit">zur Übersicht</a>
        <a href="/admin/tickets/add" class="btn-add">+ Neues Ticket anlegen</a>
    </div>

    <%- include('../partials/error-box') %>

    <div class="card">
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th class="center-td">Sichtbar</th>
                    <th>Name</th>
                    <th>Preis (€)</th>
                    <th>Kategorie</th>
                    <th>Aktionen</th>
                </tr>
            </thead>
            <tbody>
                <% tickets.forEach(ticket => { %>
                <tr>
                    <td><%= ticket.id %></td>
                    <td class="center-td">
                        <% if (ticket.visible) { %>
                            <span class="visible icon">✔</span>
                        <% } else { %>
                            <span class="hidden icon">✘</span>
                        <% } %>
                    </td>
                    <td><%= ticket.name %></td>
                    <td><%= ticket.preis.toFixed(2) %></td>
                    <td>
                        <% if (ticket.Kategorie) { %>
                            <% if (ticket.Kategorie.visible) { %>
                                <span class="visible">
                            <% } else { %>
                                <span class="hidden">
                            <% } %>
                            <%= ticket.Kategorie.name %>
                        <% } else { %>
                            Keine Kategorie
                        <% } %>
                    </td>
                    <td>
                        <a href="/admin/tickets/edit/<%= ticket.id %>" class="btn-edit">Bearbeiten</a> 
                        <form action="/admin/tickets/delete/<%= ticket.id %>" method="POST" style="display:inline;" onsubmit="return confirm('Wirklich löschen?')">
                            <button type="submit" class="btn-del">Löschen</button>
                        </form>
                    </td>
                </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</body>
</html>