<nav class="top-nav">
    <!-- Kategorien sind immer klickbar -->
    <a href="/kategorien" class="nav-item <%= currentPage === 'kategorien' ? 'active' : '' %>">
        Kategorien
    </a>
<!-- <%= JSON.stringify(locals) %> -->
    <!-- Tickets nur klickbar, wenn man in einer Kategorie ist (oder schon Items hat) -->
    <% if ( session && session.CategoryName && session.CategoryId ) { %>
        <a href="/kategorien/<%= session.CategoryId %>" class="nav-item <%= currentPage === 'tickets' ? 'active' : '' %>">Tickets (<%= session.CategoryName %>)</a>
    <% } else { %>
        <span class="nav-item disabled">Tickets</span>
    <% } %>

    <!-- Warenkorb nur klickbar, wenn er nicht leer ist -->
    <% if (cartCount > 0) { %>
        <a href="/cart" class="nav-item <%= currentPage === 'cart' ? 'active' : '' %>">
            Warenkorb <span class="cart-badge"><%= cartCount %></span>
        </a>
    <% } else { %>
        <span class="nav-item disabled">Warenkorb</span>
    <% } %>
</nav>