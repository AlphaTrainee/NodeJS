<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <link rel="stylesheet" href="/frontend_style.css">
    <title>Warenkorb</title>
</head>
<body>
    <%- include('../partials/frontend-nav') %>
    <%- include('../partials/error-box') %>

    <div class="content-container">
        <h2>Ihre Auswahl</h2>

        <div class="cart-list">
            <% if (cart.length > 0) { %>
                <% cart.forEach((item, index) => { %>
                    <div class="cart-item">
                        <span class="item-details">
                            <span class="qty"><%= item.quantity %>x</span> 
                            <%= item.name %>
                        </span>
                        
                        <div class="item-controls">
                            <strong><%= (Number(item.preis) * Number(item.quantity)).toFixed(2) %> €</strong>
                            <a href="/cart/add/<%= item.id %>" class="btn-add">+</a>
                            <a href="/cart/remove/<%= item.id %>" class="btn-remove">−</a>
                            <a href="/cart/delete/<%= item.id %>" class="btn-delete">🗑</a>
                        </div>
                    </div>
                <% }) %>

                <div class="total-row">
                    <span>Gesamtsumme:</span>
                    <span class="total-price"><%= total.toFixed(2) %> €</span>
                </div>

                <div class="touch-grid">
                    <a href="/checkout" class="touch-button pay-btn">
                        JETZT BEZAHLEN
                    </a>
                    <a href="/categories" class="touch-button alt-btn">
                        WEITERE TICKETS
                    </a>
                </div>
            <% } else { %>
                <p>Ihr Warenkorb ist leer.</p>
                <a href="/categories" class="btn-secondary">Zurück zur Auswahl</a>
            <% } %>
        </div>

        <%- include('../partials/frontend-footer') %>
    </div>
    <%- include('../partials/inactivity') %>
</body>
</html>