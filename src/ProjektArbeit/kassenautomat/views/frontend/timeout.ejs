<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sitzung läuft ab</title>
    <link rel="stylesheet" href="/frontend_style.css">
    <link rel="stylesheet" href="/timeout.css">
</head>
<body class="timeout-page" onclick="history.back()">

    <h1>Hallo, sind Sie noch da?</h1>
    <p>Der Vorgang wird ohne Ihre Bestätigung abgebrochen!</p>

    <div class="progress-wrapper">
        <div id="progress-fill"></div>
    </div>

    <div class="action-area">
        <a href="javascript:history.back()" class="btn-secondary">JA, ICH BIN NOCH DA</a>
    </div>

    <script>
        const countdownDuration = 15; // Sekunden
        let timeLeft = countdownDuration;
        const bar = document.getElementById('progress-fill');

        const countdownInterval = setInterval(() => {
            timeLeft--;
            
            // Berechnung der Breite
            const widthPercent = (timeLeft / countdownDuration) * 100;
            bar.style.width = widthPercent + "%";

            // Farbwechsel bei weniger als 5 Sekunden
            if (timeLeft <= 5) {
                bar.classList.add('progress-low');
            }

            // Ablauf des Timers
            if (timeLeft <= 0) {
                clearInterval(countdownInterval);
                window.location.href = "/";
            }
        }, 1000);
    </script>
</body>
</html>