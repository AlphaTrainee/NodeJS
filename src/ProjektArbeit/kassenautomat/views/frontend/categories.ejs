<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <link rel="stylesheet" href="/frontend_style.css">
    <title>Kategorie wählen</title>
</head>
<body>
    <%- include('../partials/frontend-nav') %>
    <%- include('../partials/error-box') %>

    <div class="content-container">
    <% if (bestsellers && bestsellers.length > 0) { %>
        <h2>Bestseller</h2>
        <div class="bestseller-grid">
            <% bestsellers.slice(0, 8).forEach(item => { %>
                <a href="/cart/add-by-name?name=<%= encodeURIComponent(item.ticketName) %>" class="bestseller-item">
                    <span class="star">★</span>
                    <span class="name"><%= item.ticketName %></span>
                </a>
            <% }) %>
        </div>
        <hr class="separate-line">
    <% } %>

    <h2>Alle Kategorien</h2>
        
        <div class="touch-grid">
            <% categories.forEach(kat => { %>
                <a href="/categories/<%= kat.id %>" class="touch-button">
                    <%= kat.name %>
                    <% if(kat.description) { %>
                        <span class="description"><%= kat.description %></span>
                    <% } %>
                </a>
            <% }) %>
        </div>
        <%- include('../partials/frontend-footer') %>
    </div>
    <%- include('../partials/inactivity') %>
</body>
</html>